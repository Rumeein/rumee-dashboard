rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════
// SAFE INCREMENTAL VERSION (dashboard memory active.md #46, 2026-07-12) --
// adds real rules for the NEW collections built this cycle (rumee_users,
// Materials/Conversions/BOM/Stock Ledger) and upgrades Purchases to
// the new role-based owner/staff functions. Everything else -- product_
// master/needs_review/pm_overrides and the ~19 analytics collections --
// is left EXACTLY as it is actually live in production today (verified
// against commit cbefc2a, the last version confirmed published via curl,
// dashboard memory MEMORY.md 2026-07-08 entry), NOT the full-lockdown
// version. Do not change those blocks here without a separate, deliberate
// decision -- see firestore.rules.future_full_lockdown.txt for that plan.
//
// Why not the full lockdown now: index.html's DASHBOARD_LOGIN_REQUIRED
// flag is still off, so the live public dashboard never signs anyone in
// for product_master/analytics reads -- gating those to isOwner() here
// would break the live site immediately with no login screen to recover
// through. Also Vantage's context_builder.py still reads the analytics
// collections via the plain public API key (not yet migrated to Admin
// SDK) -- gating those breaks Vantage's daily brief too. Both migrations
// are tracked separately (active.md "Deferred" section) and must land
// before firestore.rules.future_full_lockdown.txt gets published.
//
// Safe to publish now because: rumee_users/rumeein@gmail.com (role=owner)
// was seeded 2026-07-12 via a one-off GitHub Actions run of
// `process.py --seed-users` (Admin SDK, bypasses these rules) -- verified
// directly in that job's logs, not just the green checkmark. Every
// isOwner()/isStaffOrOwner() check below depends on that doc existing;
// without it NOBODY, including Jaiswal, would pass those checks the
// moment this publishes.
//
// Pipeline writes (process.py, GitHub Actions) always use the Admin SDK
// (service account) and always bypass these rules regardless -- none of
// this affects the pipeline in any way, only client requests using the
// public FB_API_KEY.
// ═══════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // Role lookup -- doc id = the signed-in user's own email (not their
    // uid) -- lets Jaiswal provision someone by typing their email BEFORE
    // that person has ever signed in once.
    function userRole() {
      return get(/databases/$(database)/documents/rumee_users/$(request.auth.token.email)).data.role;
    }
    function isOwner() {
      return request.auth != null && userRole() == 'owner';
    }
    // Staff can enter Purchases/Materials data but nothing else (Jaiswal,
    // 2026-07-11) -- applied only to the specific collections below, never
    // as a blanket replacement for isOwner().
    function isStaffOrOwner() {
      return request.auth != null && (userRole() == 'owner' || userRole() == 'staff');
    }

    match /rumee_users/{userId} {
      // Anyone signed in can read their OWN role doc -- this is what makes
      // userRole()'s get() above resolve without circularity: a user
      // checking their own doc always matches the first clause directly,
      // never needs isOwner() to already be true. Reading anyone ELSE's
      // entry (the Manage Users list) requires actually being an owner.
      allow read: if request.auth != null && (request.auth.token.email == userId || isOwner());
      // Only an owner can grant/change access, and never by removing their
      // OWN owner doc (guards against a self-lockout with no other owner
      // provisioned yet) -- the UI also blocks this, this is the real
      // enforcement boundary.
      allow create, update: if isOwner();
      allow delete: if isOwner() && userId != request.auth.token.email;
    }

    // ── product_master / needs_review / pm_overrides ──────────────────────
    // UNCHANGED from what is actually live today (commit cbefc2a). Reads
    // stay public (index.html has no login for this tab and
    // DASHBOARD_LOGIN_REQUIRED is off); product_master's update path has
    // never required auth at all (it's the dashboard's own public-API-key
    // write, predating any Firebase Auth in this codebase) -- only the
    // field-level shape restrictions from the 2026-07-02 review apply.
    match /product_master/{docId} {
      allow read: if true;

      allow create: if false; // pipeline (Admin SDK) creates docs, not the public client

      allow update: if
        // sku_id and created_at can never be touched by a public write
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['sku_id', 'created_at'])
        // only these top-level fields may change
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['design', 'variation_type', 'status', 'fk_url', 'notes', 'listings'])
        // listings, if touched, may only grow (append-only — no edit/remove of existing entries)
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['listings'])
          || request.resource.data.listings.size() >= resource.data.listings.size()
        );

      allow delete: if false;
    }

    match /needs_review/{docId} {
      allow read: if true;
      allow create: if false; // pipeline (Admin SDK) only

      allow update: if false;

      // Delete only allowed once the matching pm_overrides doc exists —
      // i.e. only as the LAST step of a real Assign flow, not a free-standing
      // public delete. needs_review id is 'nr_{platform}_{catalog_id}';
      // pm_overrides id is 'nr_' stripped, i.e. '{platform}_{catalog_id}'.
      allow delete: if exists(/databases/$(database)/documents/pm_overrides/$(docId[3:]));
    }

    match /pm_overrides/{docId} {
      allow read: if true;

      // Create only allowed if a matching needs_review doc exists for this
      // exact platform_catalog_id — prevents an anonymous client from
      // fabricating an arbitrary catalog_id -> target_sku_id mapping that
      // the pipeline would otherwise trust unconditionally on its next run.
      allow create: if exists(/databases/$(database)/documents/needs_review/$('nr_' + docId));

      allow update: if false;
      allow delete: if false;
    }

    // ── Purchases module ────────────────────────────────────────────────
    // Upgraded from the old hardcoded-email isOwner() to the new
    // role-based functions (safe now that rumee_users is seeded), plus
    // the entered_by binding and explicit delete:false added by the
    // 2026-07-11 independent security review. Staff access is new here
    // (Jaiswal, 2026-07-11 — staff should be able to enter Purchases).
    match /rumee_purchases/{docId} {
      allow read: if isStaffOrOwner();

      // New purchases are always entered active — void is a later action,
      // never the initial state. entered_by must match the caller's own
      // token — without this a staff account could forge entered_by to
      // impersonate the owner in the audit trail.
      allow create: if isStaffOrOwner()
        && request.resource.data.status == 'active'
        && request.resource.data.entered_by == request.auth.token.email;

      // Two independent update paths:
      //
      // (A) Narrow path — payment_status/amount_paid, status (toggles
      // between active and void only — financial records are never
      // deleted), and qc_events (append-only, new events over time).
      // entered_by can't be touched here — hasOnly() excludes it already.
      //
      // (B) Full-edit path — any other header/detail field, but never
      // touches status or qc_events in the same write, so a full edit can
      // never accidentally flip status or tamper with QC history.
      // purchase_id and entered_by must also stay unchanged here — the
      // 2026-07-12 independent review of this file caught that path (B)
      // previously had no field restriction at all beyond status/qc_events,
      // so a staff/owner edit could silently rewrite entered_by (or
      // purchase_id) and defeat the same audit-trail protection create()
      // already enforces.
      allow update: if isStaffOrOwner()
        && request.resource.data.entered_by == resource.data.entered_by
        && request.resource.data.purchase_id == resource.data.purchase_id
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['payment_status', 'amount_paid', 'status', 'qc_events'])
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
              || (resource.data.status == 'active' && request.resource.data.status == 'void')
              || (resource.data.status == 'void' && request.resource.data.status == 'active')
            )
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['qc_events'])
              || (
                // Tightened from ">=" to "== old + 1" (independent review,
                // 2026-07-13, of the bypassed:true clause just below): the
                // OLD ">=" invariant let a single write append MULTIPLE
                // events at once, and the bypassed check below only ever
                // looks at the LAST one -- a staff account crafting a raw
                // multi-element write directly via the Firestore SDK/REST
                // (bypassing this app's own saveQcEvent(), which only ever
                // appends one) could hide a bypassed:true event at position
                // N-1 where isOwner() is never evaluated for it. Requiring
                // exactly +1 growth matches actual real usage (saveQcEvent
                // always appends exactly one) and makes "the last element"
                // unambiguously "the only new element" -- no room to smuggle
                // a second, unchecked one in.
                request.resource.data.qc_events.size() == resource.data.qc_events.size() + 1
                // Bypassed QC (Jaiswal, 2026-07-13: "QC bypass will happen
                // only from my ID") is a normal qc_events append -- except
                // the newly appended event specifically requires isOwner()
                // when it's tagged bypassed:true. Normal QC entries
                // (bypassed absent or false) stay open to staff+owner,
                // unchanged.
                && (
                  isOwner()
                  || !request.resource.data.qc_events[request.resource.data.qc_events.size()-1].get('bypassed', false)
                )
              )
            )
          )
          ||
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'qc_events'])
          )
        );

      allow delete: if false; // corrections go through status=void, never a real delete
    }

    match /rumee_payees/{docId} {
      // Vendor + job-worker picker list — small reference data. Staff
      // needs this to enter Purchases (vendor/job-worker picker), same as
      // owner. delete: if false -- plain "write" implicitly grants delete
      // too, which contradicts this collection's own void/restore
      // convention.
      allow read, create, update: if isStaffOrOwner();
      allow delete: if false;
    }

    match /rumee_pur_categories/{docId} {
      // Purchase line-item category list — Earring/Raw Material/Packaging/
      // Other plus whatever Jaiswal adds, each with its own qc_enabled/
      // design_id_enabled flags. Same shape and access as rumee_payees.
      allow read, create, update: if isStaffOrOwner();
      allow delete: if false;
    }

    // ── BOM / Materials costing system ──────────────────────────────────
    // Brand new collections, never live before -- raw material / component
    // master, job-work conversion batches, and the stock movement ledger.
    // Staff can enter this too (Jaiswal, 2026-07-11 — e.g. a helper
    // logging a job-work batch). delete: if false + entered_by binding
    // per the 2026-07-11 security review, same reasoning as Purchases.
    match /rumee_materials/{docId} {
      allow read: if isStaffOrOwner();
      // entered_by locked to whoever created the doc -- update alone had no
      // field restriction at all until the 2026-07-12 independent review of
      // this file caught it (a staff/owner update could silently rewrite
      // entered_by, defeating the same audit-trail protection create()
      // already enforced).
      allow update: if isStaffOrOwner() && request.resource.data.entered_by == resource.data.entered_by;
      allow create: if isStaffOrOwner() && request.resource.data.entered_by == request.auth.token.email;
      allow delete: if false;
    }
    match /rumee_conversions/{docId} {
      allow read: if isStaffOrOwner();
      allow update: if isStaffOrOwner() && request.resource.data.entered_by == resource.data.entered_by;
      allow create: if isStaffOrOwner() && request.resource.data.entered_by == request.auth.token.email;
      allow delete: if false;
    }
    match /rumee_stock_ledger/{docId} {
      // Append-only audit trail -- no update either, only create (+read).
      allow read: if isStaffOrOwner();
      allow create: if isStaffOrOwner() && request.resource.data.entered_by == request.auth.token.email;
      allow update: if false;
      allow delete: if false;
    }

    // BOM (Bill of Material) -- one doc per output material, id = that
    // material's own material_id. Defined explicitly before any real batch
    // runs (dashboard memory active.md #50, 2026-07-12 -- renamed from
    // "Recipe" everywhere, including this collection, per Jaiswal: a
    // UI-only relabel would leave a confusing internal/external name
    // mismatch for a future developer or another tenant using this
    // product). Same access as the collections above -- not a financial
    // record itself, but directly drives derived cost.
    match /rumee_boms/{docId} {
      allow read: if isStaffOrOwner();
      allow update: if isStaffOrOwner() && request.resource.data.entered_by == resource.data.entered_by;
      allow create: if isStaffOrOwner() && request.resource.data.entered_by == request.auth.token.email;
      allow delete: if false;
    }

    // ── Every analytics collection — UNCHANGED from what is actually live
    // today (commit cbefc2a). Vantage's context_builder.py/brief_builder.py
    // still reads every one of these via the same plain public-API-key
    // mechanism (not a service account) -- locking any of these down would
    // break Vantage's daily brief before its Admin SDK migration lands.
    // The dashboard itself also reads these with no login prompt while
    // DASHBOARD_LOGIN_REQUIRED is off.
    //
    // Explicit list, not a wildcard: Firestore ORs every matching `match`
    // block, so a trailing `match /{document=**} { allow ...: if true }`
    // would silently override every specific restriction above regardless
    // of order (confirmed via Rules Playground, 2026-07-05 incident).
    match /rumee_db/{docId}               { allow read, write: if true; }
    match /rumee_insights/{docId}         { allow read, write: if true; }
    match /rumee_tasks/{docId}            { allow read, write: if true; }
    match /rumee_settings/{docId}         { allow read, write: if true; }
    match /rumee_fk_daily/{docId}         { allow read, write: if true; }
    match /rumee_me_daily/{docId}         { allow read, write: if true; }
    match /rumee_fk_returns_daily/{docId} { allow read, write: if true; }
    match /rumee_fk_ads_daily/{docId}     { allow read, write: if true; }
    match /rumee_fk_ads_kw/{docId}        { allow read, write: if true; }
    match /rumee_fk_ads_sku/{docId}       { allow read, write: if true; }
    match /rumee_fk_ads_placements/{docId}  { allow read, write: if true; }
    match /rumee_fk_ads_order_items/{docId} { allow read, write: if true; }
    match /rumee_me_ads_daily/{docId}     { allow read, write: if true; }
    match /rumee_me_ads_catalog/{docId}   { allow read, write: if true; }
    match /rumee_keywords/{docId}         { allow read, write: if true; }
    match /rumee_az_catalog/{docId}       { allow read, write: if true; }
    match /rumee_az_daily/{docId}         { allow read, write: if true; }
    match /rumee_orders_daily/{docId}     { allow read, write: if true; }
    match /rumee_orders_sku/{docId}       { allow read, write: if true; }

    // Deny by default. Anything not explicitly matched above (including
    // any future new collection someone forgets to add here) is closed,
    // not silently open. Add a new match block above whenever a new
    // collection is introduced.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
