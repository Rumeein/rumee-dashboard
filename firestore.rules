rules_version = '2';

// Scoped to product_master / needs_review / pm_overrides only — the first
// write paths ever added from the public dashboard (index.html, public
// FB_API_KEY, no login/auth). All other collections are left exactly as
// they were (fully open) — this file does not change behavior anywhere
// else. Pipeline writes via the Admin SDK (service account) and always
// bypasses these rules regardless — this only constrains the public client.
//
// Decided 2026-07-02 (see DOCS.md §22 Decisions): protects the top-level
// scalar fields the dashboard is allowed to touch. Firestore cannot
// validate individual fields inside an array element, so 'listings' is
// restricted to append-only (size can't shrink) rather than field-level
// — accepted gap, since the dashboard's only write into listings[] is an
// arrayUnion append via the Assign flow, never an edit of existing entries.

service cloud.firestore {
  match /databases/{database}/documents {

    match /product_master/{docId} {
      allow read: if true;

      allow create: if false; // pipeline (Admin SDK) creates docs, not the public client

      allow update: if
        // sku_id and created_at can never be touched by a public write
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['sku_id', 'created_at'])
        // only these top-level fields may change
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['design', 'variation_type', 'status', 'fk_url', 'notes', 'listings'])
        // listings, if touched, may only grow (append-only — no edit/remove of existing entries)
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['listings'])
          || request.resource.data.listings.size() >= resource.data.listings.size()
        );

      allow delete: if false;
    }

    match /needs_review/{docId} {
      allow read: if true;
      allow create: if false; // pipeline (Admin SDK) only

      allow update: if false;

      // Delete only allowed once the matching pm_overrides doc exists —
      // i.e. only as the LAST step of a real Assign flow, not a free-standing
      // public delete. needs_review id is 'nr_{platform}_{catalog_id}';
      // pm_overrides id is 'nr_' stripped, i.e. '{platform}_{catalog_id}'.
      // Added 2026-07-02 after security review — closes an unpaired public
      // delete gap on this collection.
      allow delete: if exists(/databases/$(database)/documents/pm_overrides/$(docId[3:]));
    }

    match /pm_overrides/{docId} {
      allow read: if true;

      // Create only allowed if a matching needs_review doc exists for this
      // exact platform_catalog_id — prevents an anonymous client from
      // fabricating an arbitrary catalog_id -> target_sku_id mapping that
      // the pipeline would otherwise trust unconditionally on its next run.
      // Added 2026-07-02 after security review.
      allow create: if exists(/databases/$(database)/documents/needs_review/$('nr_' + docId));

      allow update: if false;
      allow delete: if false;
    }

    // Purchases module (DOCS.md §26 / dashboard memory active.md #25).
    // First browser-authenticated write path in this codebase — added
    // 2026-07-05 alongside enabling Firebase Authentication (Google
    // Sign-In). Unlike product_master, READ is also restricted here, not
    // just write: index.html is public and its FB_API_KEY is visible in
    // view-source, so an open read rule would let anyone pull vendor
    // invoice numbers, GSTIN, and cost data directly via the Firestore
    // REST API. Pipeline/Admin SDK writes (the one-time historical
    // importer) always bypass these rules regardless.
    function isOwner() {
      return request.auth != null && request.auth.token.email == 'rumeein@gmail.com';
    }

    match /rumee_purchases/{docId} {
      allow read: if isOwner();

      // New purchases are always entered active — void is a later action,
      // never the initial state.
      allow create: if isOwner() && request.resource.data.status == 'active';

      // Two independent update paths (Jaiswal asked for full edit access on
      // 2026-07-07/08, on top of the original void+re-enter design):
      //
      // (A) Narrow path — payment_status/amount_paid (a bill can legitimately
      // receive more payment later, or Amount Paid needs correcting),
      // status (toggles between active and void only — void must be
      // reversible, financial records are never deleted, 2026-07-07), and
      // qc_events (QC happens gradually, new events append over time).
      //
      // (B) Full-edit path — any other header/detail field (vendor, date,
      // category, GST/packing/courier/other_transport, invoice/GSTIN,
      // payment_mode, notes, details[]) may change via the "Edit" button,
      // but this path is NOT allowed to touch status or qc_events in the
      // same write — those stay governed only by path (A)'s dedicated
      // actions (Void/Restore, QC entry), so a full edit can never
      // accidentally flip status or tamper with QC history. purchase_id is
      // never included in either path's write, so it's implicitly immutable.
      allow update: if isOwner()
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['payment_status', 'amount_paid', 'status', 'qc_events'])
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
              || (resource.data.status == 'active' && request.resource.data.status == 'void')
              || (resource.data.status == 'void' && request.resource.data.status == 'active')
            )
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['qc_events'])
              || request.resource.data.qc_events.size() >= resource.data.qc_events.size()
            )
          )
          ||
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'qc_events'])
          )
        );

      allow delete: if false; // corrections go through status=void, never a real delete
    }

    match /rumee_payees/{docId} {
      // Vendor + job-worker picker list (active.md #25) — small reference
      // data, no embedded arrays, no in-place-edit concerns. Same
      // owner-only access as rumee_purchases, same reason (public
      // FB_API_KEY exposure).
      allow read, write: if isOwner();
    }

    // Every other collection the dashboard/pipeline/Vantage currently
    // depend on being publicly readable/writable via the plain FB_API_KEY
    // (no auth) — preserved exactly as-is. Explicitly enumerated instead
    // of a blanket wildcard.
    //
    // WHY explicit, not a wildcard (found + fixed 2026-07-05): Firestore
    // combines every `match` block that applies to a path with OR logic,
    // not most-specific-wins (see rules-structure docs: "access is
    // allowed if any of the conditions is true"). A trailing
    // `match /{document=**} { allow read, write: if true; }` matches
    // EVERY path, including product_master/rumee_purchases/etc above, and
    // since it always evaluates true it silently overrides every
    // restriction in this file regardless of order. That wildcard is why
    // the 2026-07-02 product_master restrictions, and this session's new
    // rumee_purchases/rumee_payees restrictions, never actually took
    // effect — confirmed via Firebase's Rules Playground. Deny-by-default
    // (explicit allow list + `if false` catch-all) is Firestore's own
    // recommended pattern and the only way specific restrictions above
    // can coexist with "everything else stays open."
    //
    // List confirmed via codebase grep (index.html, process.py,
    // firestore_connector.py) plus a check of vantage-agent's
    // brief_builder.py/context_builder.py, which reads this same
    // Firestore project via the same plain-API-key mechanism (not a
    // service account) for all of these — locking any of these down
    // would break Vantage's daily brief, not just the dashboard.
    match /rumee_db/{docId}               { allow read, write: if true; }
    match /rumee_insights/{docId}         { allow read, write: if true; }
    match /rumee_tasks/{docId}            { allow read, write: if true; }
    match /rumee_settings/{docId}         { allow read, write: if true; }
    match /rumee_fk_daily/{docId}         { allow read, write: if true; }
    match /rumee_me_daily/{docId}         { allow read, write: if true; }
    match /rumee_fk_returns_daily/{docId} { allow read, write: if true; }
    match /rumee_fk_ads_daily/{docId}     { allow read, write: if true; }
    match /rumee_fk_ads_kw/{docId}        { allow read, write: if true; }
    match /rumee_fk_ads_sku/{docId}       { allow read, write: if true; }
    match /rumee_fk_ads_placements/{docId}  { allow read, write: if true; }
    match /rumee_fk_ads_order_items/{docId} { allow read, write: if true; }
    match /rumee_me_ads_daily/{docId}     { allow read, write: if true; }
    match /rumee_me_ads_catalog/{docId}   { allow read, write: if true; }
    match /rumee_keywords/{docId}         { allow read, write: if true; }
    match /rumee_az_catalog/{docId}       { allow read, write: if true; }
    match /rumee_az_daily/{docId}         { allow read, write: if true; }
    match /rumee_orders_daily/{docId}     { allow read, write: if true; }
    match /rumee_orders_sku/{docId}       { allow read, write: if true; }

    // Deny by default. Anything not explicitly matched above (including
    // any future new collection someone forgets to add here) is closed,
    // not silently open. Add a new match block above whenever a new
    // collection genuinely needs public access.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
