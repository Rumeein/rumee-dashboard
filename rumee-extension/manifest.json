{
  "manifest_version": 3,
  "name": "Rumee — Auto Sync",
  "version": "1.0.0",
  "description": "Downloads Flipkart & Meesho reports and uploads directly to Google Drive.",

  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "identity"
  ],

  "host_permissions": [
    "https://seller.flipkart.com/*",
    "https://seller-api.flipkart.com/*",
    "https://supplier.meesho.com/*",
    "https://www.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://supplier.meesho.com/*"],
      "js": ["config.js", "content/meesho.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://seller.flipkart.com/*"],
      "js": ["config.js", "content/flipkart.js"],
      "run_at": "document_idle"
    }
  ],

  "oauth2": {
    "client_id": "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
