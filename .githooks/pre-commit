#!/bin/sh
# PM Discipline — pre-commit hook
# Blocks commit on code files unless review_pass.json is complete.
#
# Validation only. Deliberately does NOT delete review_pass.json or claim to
# add the [PM-REVIEWED] tag itself -- a pre-commit hook runs before the
# commit object exists and cannot rewrite the message text a caller already
# passed via `git commit -m`. That used to be exactly what this hook's last
# line claimed ("[PM-REVIEWED] tag will be added to commit message") without
# ever actually doing it -- three commits in a row (83c36c5, 9c5265b,
# 9f79dce, 2026-07-11) passed this local check yet still failed the
# server-side "PM Discipline Check" GitHub Actions job, which greps the
# real commit message for the literal tag. Fixed by moving the actual tag
# injection to .githooks/prepare-commit-msg (a hook type that CAN edit the
# message), which runs immediately after this one and consumes/deletes
# review_pass.json itself once it has appended the tag.

CODE_EXTENSIONS="\.py$|\.html$|\.js$|\.mjs$"
REVIEW_FILE="review_pass.json"

# Check if any staged file is a code file
CODE_CHANGED=$(git diff --cached --name-only | grep -E "$CODE_EXTENSIONS" | grep -v "$REVIEW_FILE" | head -1)

if [ -z "$CODE_CHANGED" ]; then
  exit 0  # No code files staged — data/config commit, skip check
fi

# Code files are staged — require review_pass.json
if [ ! -f "$REVIEW_FILE" ]; then
  echo ""
  echo "BLOCKED: Code files staged but review_pass.json not found."
  echo "Copy review_pass.template.json → review_pass.json and fill all fields."
  echo ""
  exit 1
fi

# Validate all required fields are present and non-empty
python3 - << 'PYEOF'
import json, sys

try:
    with open("review_pass.json", encoding="utf-8") as f:
        r = json.load(f)
except Exception as e:
    print(f"\nBLOCKED: review_pass.json is not valid JSON: {e}\n")
    sys.exit(1)

required = {
    "understand":              "done",
    "plan_approved":           "yes",
    "review_matches_plan":     "yes",
    "review_breaks_anything":  "no",
    "review_security":         "clean",
    "verify_instruction":      None,   # any non-empty string
}

errors = []
for field, expected in required.items():
    val = r.get(field, "").strip()
    if not val:
        errors.append(f"  - '{field}' is empty")
    elif expected and val != expected:
        errors.append(f"  - '{field}' must be '{expected}', got '{val}'")

if errors:
    print("\nBLOCKED: review_pass.json has errors:")
    for e in errors:
        print(e)
    print("\nFix the checklist and retry.\n")
    sys.exit(1)

print(f"\nPM review passed. verify: {r['verify_instruction']}\n")
sys.exit(0)
PYEOF

STATUS=$?
if [ $STATUS -ne 0 ]; then
  exit 1
fi

# Checklist passed. Leave review_pass.json in place -- prepare-commit-msg
# (runs next) reads it to actually inject [PM-REVIEWED] into the message,
# then deletes it. Not deleted here.
exit 0
